PORT=5000
APP_TIME_ZONE=Asia/Ho_Chi_Minh

DB_HOST=your-railway-mysql-host
DB_PORT=3306
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_DATABASE=medpulse_db
DB_SSL_ENABLED=true
DB_SSL_REJECT_UNAUTHORIZED=false
REGISTRATION_DB_TIMEOUT_MS=8000

MQTT_BROKER_URL=ws://broker.hivemq.com:8000/mqtt
MQTT_ROOT_TOPIC=medpulse_duy
# Production: dùng broker riêng và root topic riêng, không giữ hai giá trị mặc định trên.
# MQTT_USER=
# MQTT_PASSWORD=

BLE_DEVICE_SEEN_STALE_MS=45000
BLE_GATT_READY_STALE_MS=45000
BLE_ALERT_TIMEOUT_MS=180000
STATION_OFFLINE_TIMEOUT_MS=90000
DIRECT_DEVICE_TIMEOUT_MS=90000
DEVICE_COMMAND_ACK_TIMEOUT_MS=20000
DEVICE_COMMAND_RETRY_INTERVAL_MS=5000

# Tài khoản quản lý được bootstrap một lần; mật khẩu tối thiểu 10 ký tự và được băm scrypt.
MANAGER_EMAIL=manager@example.com
MANAGER_PASSWORD=replace-with-a-strong-manager-password
AUTH_SESSION_TTL_MS=28800000
# Demo login chỉ dùng khi test nội bộ; giữ false khi nộp/deploy để chỉ dùng tài khoản manager.
ALLOW_DEMO_LOGIN=false
# Đặt true khi muốn production fail-fast nếu còn dùng broker/root topic/demo login không an toàn.
ENFORCE_PRODUCTION_CONFIG=false

# Gmail SMTP: dùng App Password, không dùng mật khẩu đăng nhập Gmail.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=manager@example.com
SMTP_APP_PASSWORD=replace-with-google-app-password
SMTP_FROM=MedPulse <manager@example.com>
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000

# Chuỗi ngẫu nhiên dài dùng HMAC cho OTP; không commit giá trị thật.
OTP_SECRET=replace-with-at-least-32-random-characters

# Khuyến nghị trên Render: gửi email qua HTTPS thay vì SMTP bị chặn.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=MedPulse <onboarding@resend.dev>
